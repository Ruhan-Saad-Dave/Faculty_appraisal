# .dockerignore - Files to exclude from GCP Production Deployment
.git
.venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
tests/
migrations/
scripts/
Docs/*.docx
Docs/*.pdf
Docs/supabase_migration_plan.md
Docs/testing_guide.md
references/
.env
.env.example
.python-version
output.txt
PART-A.pdf
uv.lock (optional, but keep for exact builds)
README.md
README.Docker.md
schema.txt
tables.txt
*.docx
*.pdf
